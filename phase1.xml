        assert_eq!(NodeKind::Parameter { index: 0 }.kind_name(), "Parameter");
        assert_eq!(NodeKind::Select { cond: nid(0), true_val: nid(1), false_val: nid(2) }.kind_name(), "Select");
        assert_eq!(
