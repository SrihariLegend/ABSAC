<script>
// ── Dependency diagram tooltips ────────────────────────────
(function() {
  const tooltip = document.getElementById('dep-tooltip');
  const nodes = document.querySelectorAll('.dep-node');

  nodes.forEach(node => {
    node.addEventListener('mouseenter', function(e) {
      const crate = this.dataset.crate;
      const desc = this.dataset.desc;
      const tests = this.dataset.tests;
      tooltip.innerHTML = `<div class="tt-name">${crate}</div><div class="tt-detail">${desc}</div><div class="tt-detail" style="margin-top:4px;font-weight:600;">${tests} unit tests</div>`;
      tooltip.classList.add('visible');
    });

    node.addEventListener('mousemove', function(e) {
      const rect = this.closest('.panel').getBoundingClientRect();
      tooltip.style.left = (e.clientX - rect.left + 12) + 'px';
      tooltip.style.top = (e.clientY - rect.top - 50) + 'px';
    });

    node.addEventListener('mouseleave', function() {
      tooltip.classList.remove('visible');
    });
  });
})();
</script>

