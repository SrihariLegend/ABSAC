        assert_eq!(c, parsed);
    }

    #[test]
    fn serde_roundtrip_float() {
        let c = ConstantData::f64(1.5);
        let json = serde_json::to_string(&c).unwrap();
        let parsed: ConstantData = serde_json::from_str(&json).unwrap();
        assert_eq!(c, parsed);
    }
